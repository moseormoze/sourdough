{
  "$schema": "Design tokens for Kikar (Soft Bake direction). Hebrew-first, RTL.",
  "meta": {
    "name": "Kikar Design Tokens",
    "version": "0.1.0",
    "direction": "rtl",
    "base-unit": 4
  },

  "color": {
    "bg":         { "value": "#F8F5EE", "comment": "page background"                       , "var": "--bg" },
    "bg-2":       { "value": "#F2EAD8", "comment": "raised section / dough-tinted card bg" , "var": "--bg-2" },
    "paper":      { "value": "#FFFFFF", "comment": "elevated paper / card surface"         , "var": "--paper" },
    "ink":        { "value": "#1F1A14", "comment": "primary text / primary button bg"      , "var": "--ink" },
    "ink-2":      { "value": "#6E6457", "comment": "secondary text / muted ui"             , "var": "--ink-2" },
    "ink-3":      { "value": "#A6997F", "comment": "tertiary / placeholders / metadata"    , "var": "--ink-3" },
    "line":       { "value": "#EDE5D2", "comment": "subtle divider, default border"        , "var": "--line" },
    "line-2":     { "value": "#DCD0B4", "comment": "stronger divider / input border"       , "var": "--line-2" },

    "accent":     { "value": "#E66B3D", "comment": "clay / primary accent (CTA, current step)", "var": "--accent" },
    "accent-2":   { "value": "#F2BC8E", "comment": "softer accent for gradients/highlights", "var": "--accent-2" },
    "accent-3":   { "value": "#FCE7D4", "comment": "alias of accent-bg"                    , "var": "--accent-3" },
    "accent-bg":  { "value": "#FCE7D4", "comment": "accent surface (pill bg, soft hint)"   , "var": "--accent-bg" },

    "sage":       { "value": "#BFC7A0", "comment": "olive — secondary accent (success-ish)", "var": "--sage" },
    "sage-2":     { "value": "#8C9963", "comment": "olive deep — text on sage surfaces"    , "var": "--sage-2" },
    "sage-bg":    { "value": "#ECEFDC", "comment": "olive surface (success pill, check-tile)", "var": "--sage-bg" },

    "warn":       { "value": "#D38D1B", "comment": "warning / amber",                        "var": "--warn" },
    "warn-bg":    { "value": "#FBEFD0", "comment": "warning surface",                        "var": "--warn-bg" },
    "danger":     { "value": "#A14525", "comment": "destructive / error" },
    "danger-bg":  { "value": "#F8D8CE", "comment": "destructive surface" }
  },

  "shadow": {
    "sm":   { "value": "0 1px 0 rgba(31,26,20,.04), 0 4px 12px rgba(31,26,20,.04)" },
    "md":   { "value": "0 1px 0 rgba(31,26,20,.04), 0 6px 24px rgba(31,26,20,.06)", "var": "--shadow" },
    "lg":   { "value": "0 1px 0 rgba(31,26,20,.04), 0 16px 40px rgba(31,26,20,.10)", "var": "--shadow-lg" },
    "cta":  { "value": "0 1px 0 rgba(0,0,0,.06), 0 10px 24px rgba(230,107,61,.32)" , "comment": "accent CTA elevation" },
    "sheet":{ "value": "0 -10px 40px rgba(0,0,0,.18)", "comment": "bottom sheet" }
  },

  "radius": {
    "xs":   { "value": 6  },
    "sm":   { "value": 10 },
    "md":   { "value": 14 },
    "lg":   { "value": 18 },
    "xl":   { "value": 22, "comment": "buttons, tab bar" },
    "2xl":  { "value": 24, "comment": "primary cards" },
    "3xl":  { "value": 28, "comment": "bottom sheet top corners" },
    "full": { "value": 999 }
  },

  "spacing": {
    "0":    { "value": 0 },
    "1":    { "value": 4 },
    "2":    { "value": 8 },
    "3":    { "value": 12 },
    "4":    { "value": 16, "comment": "default screen padding inline" },
    "5":    { "value": 20 },
    "6":    { "value": 24, "comment": "section gap, generous padding" },
    "8":    { "value": 32 },
    "10":   { "value": 40 },
    "12":   { "value": 48 },
    "16":   { "value": 64 },
    "20":   { "value": 80 }
  },

  "type": {
    "family": {
      "ui":      "'Rubik', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "display": "'Rubik', system-ui, sans-serif",
      "mono":    "'JetBrains Mono', 'SF Mono', ui-monospace, monospace"
    },
    "display-lg":  { "size": 36, "line-height": 1.05, "weight": 600, "tracking": "-0.025em", "use": "hero on home, screen titles when standalone" },
    "display-md":  { "size": 28, "line-height": 1.1,  "weight": 600, "tracking": "-0.025em", "use": "stage titles" },
    "display-sm":  { "size": 22, "line-height": 1.15, "weight": 600, "tracking": "-0.02em",  "use": "card titles" },
    "heading":     { "size": 17, "line-height": 1.3,  "weight": 700, "tracking": "-0.015em", "use": "bottom sheet title, section heads" },
    "body-lg":     { "size": 16, "line-height": 1.5,  "weight": 400, "use": "primary instruction copy on stage screens" },
    "body":        { "size": 14, "line-height": 1.5,  "weight": 400, "use": "card body, explanations" },
    "label":       { "size": 14, "line-height": 1.4,  "weight": 500, "use": "buttons, list rows, check-tile titles" },
    "small":       { "size": 12, "line-height": 1.45, "weight": 500, "use": "captions, metadata" },
    "tiny":        { "size": 11, "line-height": 1.4,  "weight": 500, "use": "timestamps, secondary metadata" },
    "eyebrow":     { "size": 11, "line-height": 1,    "weight": 600, "tracking": "0.08em", "transform": "uppercase", "use": "section eyebrows" },
    "mono-sm":     { "size": 11, "line-height": 1.4,  "weight": 500, "family": "mono", "use": "numeric tags, timer labels" }
  },

  "motion": {
    "duration": {
      "instant": "0ms",
      "fast":    "120ms",
      "base":    "200ms",
      "slow":    "300ms",
      "deliberate": "450ms"
    },
    "easing": {
      "out":     "cubic-bezier(0.22, 1, 0.36, 1)",
      "in-out":  "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring":  "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "linear":  "linear"
    },
    "press":          { "scale": 0.965, "duration": "120ms", "easing": "out",    "comment": "default tap feedback for buttons & cards" },
    "spring-release": { "duration": "250ms", "easing": "spring",                 "comment": "after a swipe / drag release" },
    "sheet-open":     { "duration": "300ms", "easing": "out",                    "comment": "bottom sheet entry" },
    "fade":           { "duration": "200ms", "easing": "in-out" },
    "reduce-motion":  { "respect": true,                                         "comment": "all durations → 0ms when prefers-reduced-motion is set" }
  },

  "z": {
    "base":     0,
    "raised":   1,
    "sticky":   10,
    "sheet":    50,
    "toast":    100,
    "overlay":  200
  },

  "touch-target": {
    "min": 44,
    "comment": "minimum hit area for any interactive element"
  },

  "breakpoints": {
    "mobile":   { "min": 0,   "max": 599, "default-ref": 375, "comment": "primary target" },
    "tablet":   { "min": 600, "max": 1023, "comment": "future" },
    "desktop":  { "min": 1024, "comment": "out of scope for v1" }
  },

  "rtl": {
    "comment": "Hebrew-first, RTL. Use logical CSS properties only (inline-start/end, block-start/end, ms-/me-/ps-/pe-) — NEVER left/right.",
    "numbers": "wrap numeric runs in [dir=ltr] (e.g. <span dir=ltr>75%</span>) so they read 1-2-3 inside Hebrew sentences.",
    "icons": "Lucide directional icons mirror automatically when their parent is RTL. Custom icons need a manual mirror for arrows/chevrons."
  }
}
