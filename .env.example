# PostHog (analytics)
# Get the project API key from https://posthog.com → Project Settings → Project API Key
# Both vars are NEXT_PUBLIC_ prefixed because PostHog runs in the browser.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EU region (privacy + lower latency from Israel). Use https://us.i.posthog.com for US accounts.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Supabase (feature 23 — starter tracker `feedings` table only; no auth yet)
# Project URL and anon key from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
